{
    "name": "Python Sandbox",
    // Build from the Dockerfile next to this file.
    "build": {
        "dockerfile": "Dockerfile"
    },
    "runArgs": [
        "--name",
        "devcontainer-${localWorkspaceFolderBasename}"
    ],
    // Where your project gets mounted inside the container.
    // This is the ONLY host directory the container can see.
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
    "workspaceFolder": "/workspace",
    // Run as the non-root user that the base image provides.
    "remoteUser": "vscode",
    // Run after the container is built. Good place for `pip install -r requirements.txt`.
    "postCreateCommand": "pip install --user --no-cache-dir -r requirements.txt || true",
    // Cursor-specific: install extensions inside the container.
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "Anthropic.claude-code",
                "charliermarsh.ruff"
            ]
        }
    }
}